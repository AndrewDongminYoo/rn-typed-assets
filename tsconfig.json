{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",

    // Environment Settings
    "module": "commonjs",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],

    // JavaScript Support
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,

    // Recommended Options
    "strict": false,
    "skipLibCheck": true,
  },
  "include": ["src/**/*"]
}
